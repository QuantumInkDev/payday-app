<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PayDay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PayDay"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PayDay"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="PayDay"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Top"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="PayDay"
                    IsSelected="True"
                    Tag="payday">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="All Bills" Tag="bills">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Payoff Tracker" Tag="payoff">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB05;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Insights" Tag="insights">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <StackPanel
                    Margin="0,0,12,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="LastSyncedLabel"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="Never synced"
                        VerticalAlignment="Center" />
                    <ProgressRing
                        x:Name="SyncProgress"
                        Width="16"
                        Height="16"
                        IsActive="False"
                        Visibility="Collapsed" />
                    <Button
                        x:Name="SyncNowButton"
                        Click="SyncNowButton_Click"
                        ToolTipService.ToolTip="Push and pull bill changes to/from Notion">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE895;" />
                            <TextBlock Text="Sync Now" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneFooter>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PayDay.Pages.SettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PayDay.Pages"
    xmlns:conv="using:PayDay.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:NotionStatusToBrushConverter x:Key="NotionStatusBrush" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="24,16,24,24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Configure pay anchor, appearance, sync, and backup" />
            </StackPanel>

            <!-- Pay Period -->
            <Border
                Grid.Row="1"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Pay Period" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="The anchor date the biweekly cycle counts from. All three periods (This / Next / Following) are computed by walking 14 days at a time from this date." />
                    </StackPanel>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker
                            Grid.Column="0"
                            Date="{x:Bind ViewModel.PayAnchorDate, Mode=TwoWay}"
                            Header="Anchor date"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="OnSavePayAnchorClick"
                            Content="Save"
                            Style="{ThemeResource AccentButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border
                Grid.Row="2"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Appearance" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Pick a theme. 'System' follows your Windows preference." />
                    </StackPanel>
                    <RadioButtons
                        x:Name="ThemeRadios"
                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                        SelectionChanged="OnThemeChanged">
                        <RadioButton Content="System default" />
                        <RadioButton Content="Light" />
                        <RadioButton Content="Dark" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Type Colors -->
            <Border
                Grid.Row="3"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Type Colors" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Pick the pill color for each bill type. Changes apply on the next page navigation." />
                    </StackPanel>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TypeColorEntries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate xmlns:vm="using:PayDay.ViewModels" x:DataType="vm:TypeColorEntry">
                                <Grid Margin="0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        Width="28"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Background="{x:Bind Hex, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Type}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind Hex, Mode=OneWay}" />
                                    <Button
                                        Grid.Column="3"
                                        Click="OnChangeTypeColorClick"
                                        Content="Change…"
                                        Tag="{x:Bind Type}" />
                                    <Button
                                        Grid.Column="4"
                                        Click="OnResetTypeColorClick"
                                        Content="Reset"
                                        Tag="{x:Bind Type}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Backup -->
            <Border
                Grid.Row="4"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Backup &amp; Restore" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Export your bills, payments, snapshots, and settings to a JSON file, or restore from one. Import replaces all local data — make an export first if you might want to undo it." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnExportClick" Content="Export to JSON…" />
                        <Button Click="OnImportClick" Content="Import from JSON…" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Notion sync -->
            <Border
                Grid.Row="5"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Notion Sync" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            Text="Bidirectional bill sync against the 'Money Matters' databases, plus push of every payment and snapshot. Token stored in Windows Credential Manager." />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox
                            x:Name="TokenBox"
                            Grid.Column="0"
                            Header="Integration token"
                            PlaceholderText="secret_..." />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="OnSaveTokenClick"
                            Content="Save"
                            Style="{ThemeResource AccentButtonStyle}" />
                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Click="OnClearTokenClick"
                            Content="Clear"
                            IsEnabled="{x:Bind ViewModel.NotionTokenSet, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button
                            Click="OnTestNotionClick"
                            Content="Test connection"
                            IsEnabled="{x:Bind ViewModel.NotionSectionEnabled, Mode=OneWay}" />
                        <Button
                            Click="OnSyncNowClick"
                            Content="Sync now"
                            IsEnabled="{x:Bind ViewModel.NotionSectionEnabled, Mode=OneWay}" />
                        <ProgressRing
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            IsActive="{x:Bind ViewModel.IsNotionBusy, Mode=OneWay}" />
                    </StackPanel>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse
                            Width="10"
                            Height="10"
                            VerticalAlignment="Center"
                            Fill="{x:Bind ViewModel.NotionStatus, Mode=OneWay, Converter={StaticResource NotionStatusBrush}}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                FontSize="12"
                                Text="{x:Bind ViewModel.NotionStatusLabel, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="{x:Bind ViewModel.LastSyncedLabel, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border
                Grid.Row="6"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="About" />
                    <Grid ColumnSpacing="16" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Version" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontSize="12"
                            Text="v0.1.0 (Phase 4)" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Repository" />
                        <HyperlinkButton
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="0"
                            Content="github.com/QuantumInkDev/payday-app"
                            NavigateUri="https://github.com/QuantumInkDev/payday-app" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Build" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            FontSize="12"
                            Text="WinUI 3 · Windows App SDK 2.0 · .NET 9" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <InfoBar
                Grid.Row="7"
                IsClosable="True"
                IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational" />
        </Grid>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PayDay.Pages.SettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PayDay.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="24,16,24,24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Configure pay anchor, appearance, sync, and backup" />
            </StackPanel>

            <!-- Pay Period -->
            <Border
                Grid.Row="1"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Pay Period" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="The anchor date the biweekly cycle counts from. All three periods (This / Next / Following) are computed by walking 14 days at a time from this date." />
                    </StackPanel>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker
                            Grid.Column="0"
                            Date="{x:Bind ViewModel.PayAnchorDate, Mode=TwoWay}"
                            Header="Anchor date"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="OnSavePayAnchorClick"
                            Content="Save"
                            Style="{ThemeResource AccentButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border
                Grid.Row="2"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Appearance" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Pick a theme. 'System' follows your Windows preference." />
                    </StackPanel>
                    <RadioButtons
                        x:Name="ThemeRadios"
                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                        SelectionChanged="OnThemeChanged">
                        <RadioButton Content="System default" />
                        <RadioButton Content="Light" />
                        <RadioButton Content="Dark" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Backup -->
            <Border
                Grid.Row="3"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Backup &amp; Restore" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Export your bills, payments, snapshots, and settings to a JSON file, or restore from one. Import replaces all local data — make an export first if you might want to undo it." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnExportClick" Content="Export to JSON…" />
                        <Button Click="OnImportClick" Content="Import from JSON…" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Notion sync placeholder -->
            <Border
                Grid.Row="4"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Notion Sync" />
                        <Border
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="10">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                Text="PHASE 5" />
                        </Border>
                    </StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Bidirectional sync with the 'Money Matters' Notion databases lands in Phase 5. The integration token will be stored in Windows Credential Manager, and bills will sync on demand or after every payment." />
                </StackPanel>
            </Border>

            <!-- About -->
            <Border
                Grid.Row="5"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="About" />
                    <Grid ColumnSpacing="16" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Version" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontSize="12"
                            Text="v0.1.0 (Phase 4)" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Repository" />
                        <HyperlinkButton
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="0"
                            Content="github.com/QuantumInkDev/payday-app"
                            NavigateUri="https://github.com/QuantumInkDev/payday-app" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Build" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            FontSize="12"
                            Text="WinUI 3 · Windows App SDK 2.0 · .NET 9" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <InfoBar
                Grid.Row="6"
                IsClosable="True"
                IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational" />
        </Grid>
    </ScrollViewer>
</Page>

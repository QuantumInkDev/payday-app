<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PayDay.Pages.AllBillsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:PayDay.Converters"
    xmlns:models="using:PayDay.Models"
    xmlns:vm="using:PayDay.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:TypeToBrushConverter x:Key="TypeToBrush" />
        <conv:CurrencyConverter x:Key="Currency" />
        <conv:AutoPayDotConverter x:Key="AutoPayDot" />
    </Page.Resources>

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title row -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="All Bills" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.TotalBillsLabel, Mode=OneWay}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Command="{x:Bind ViewModel.RefreshCommand}"
                Content="Refresh"
                ToolTipService.ToolTip="Reload from the database" />
            <Button
                Grid.Column="2"
                Click="OnAddBillClick"
                Content="Add New Bill"
                Style="{ThemeResource AccentButtonStyle}" />
        </Grid>

        <!-- Sortable column header row. TYPE and ACTIVE are static; the rest are HyperlinkButtons that drive ViewModel.SortByCommand. -->
        <Grid
            Grid.Row="1"
            Padding="12,6"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="TYPE" />
            <HyperlinkButton
                Grid.Column="1"
                Padding="0"
                Command="{x:Bind ViewModel.SortByCommand}"
                CommandParameter="Name">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="NAME" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.NameIndicator, Mode=OneWay}" />
                </StackPanel>
            </HyperlinkButton>
            <HyperlinkButton
                Grid.Column="2"
                Padding="0"
                Command="{x:Bind ViewModel.SortByCommand}"
                CommandParameter="Payment">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="PAYMENT" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.PaymentIndicator, Mode=OneWay}" />
                </StackPanel>
            </HyperlinkButton>
            <HyperlinkButton
                Grid.Column="3"
                Padding="0"
                Command="{x:Bind ViewModel.SortByCommand}"
                CommandParameter="Remaining">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="REMAINING" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.RemainingIndicator, Mode=OneWay}" />
                </StackPanel>
            </HyperlinkButton>
            <HyperlinkButton
                Grid.Column="4"
                Padding="0"
                Command="{x:Bind ViewModel.SortByCommand}"
                CommandParameter="Due">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="DUE" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.DueIndicator, Mode=OneWay}" />
                </StackPanel>
            </HyperlinkButton>
            <HyperlinkButton
                Grid.Column="5"
                Padding="0"
                Command="{x:Bind ViewModel.SortByCommand}"
                CommandParameter="Rate">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="RATE" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.RateIndicator, Mode=OneWay}" />
                </StackPanel>
            </HyperlinkButton>
            <TextBlock
                Grid.Column="6"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="ACTIVE" />
        </Grid>

        <!-- Grouped list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BillGroup">
                        <StackPanel Margin="0,0,0,16" Spacing="6">
                            <!-- Group header -->
                            <Grid Padding="4,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Padding="10,3"
                                    VerticalAlignment="Center"
                                    Background="{x:Bind Key, Converter={StaticResource TypeToBrush}}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{x:Bind Key}" />
                                </Border>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind Count}" />
                            </Grid>

                            <!-- Bills in this group -->
                            <ItemsControl ItemsSource="{x:Bind Bills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Bill">
                                        <Border
                                            Margin="0,0,0,4"
                                            Padding="12,8"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Tapped="OnBillRowTapped"
                                            ToolTipService.ToolTip="Click to edit">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>

                                                <!-- AutoPay dot + label -->
                                                <StackPanel
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="6">
                                                    <Ellipse
                                                        Width="8"
                                                        Height="8"
                                                        Fill="{x:Bind AutoPay, Converter={StaticResource AutoPayDot}}"
                                                        ToolTipService.ToolTip="Auto-pay (green) or manual (amber)" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        Text="{x:Bind Type}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        Text="{x:Bind Notes}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind Payment, Converter={StaticResource Currency}}" />

                                                <TextBlock
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind Remaining, Converter={StaticResource Currency}}" />

                                                <TextBlock
                                                    Grid.Column="4"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind DueDay}" />

                                                <TextBlock
                                                    Grid.Column="5"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Text="{x:Bind Rate}" />

                                                <ToggleSwitch
                                                    Grid.Column="6"
                                                    VerticalAlignment="Center"
                                                    IsOn="{x:Bind Active, Mode=OneWay}"
                                                    MinWidth="0"
                                                    OffContent=""
                                                    OnContent=""
                                                    Toggled="OnActiveToggled" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
